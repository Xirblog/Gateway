{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Yarp.ReverseProxy": "Information"
    }
  },
  "ReverseProxy": {
    "Routes": {
      "user-route": {
        "ClusterId": "user-cluster",
        "Match": {
          "Path": "/api/users/{**catch-all}"
        },
        "Transforms": [
          { "PathPattern": "{**catch-all}" }
        ]
      },
      "post-route": {
        "ClusterId": "post-cluster",
        "Match": {
          "Path": "/api/posts/{**catch-all}"
        },
        "Transforms": [
          { "PathPattern": "{**catch-all}" }
        ]
      }
    },
    "Clusters": {
      "user-cluster": {
        "Destinations": {
          "user-service": {
            "Address": "http://user-service:8080"
          }
        },
        "HttpClient": {
          "Timeout": "00:00:30"
        }
      },
      "post-cluster": {
        "Destinations": {
          "post-service": {
            "Address": "http://post-service:8080"
          }
        },
        "HttpClient": {
          "Timeout": "00:00:30"
        }
      }
    }
  }
}
